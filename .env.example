# Telegram
BOT_TOKEN=1234567890:REEMPLAZA_CON_EL_TOKEN_DE_BOTFATHER
# Opcional: valida que el token pertenezca al bot numérico esperado.
BOT_ID=1234567890
ADMIN_IDS=123456789

# Base de datos: SQLite funciona sin instalar ningún servidor adicional.
DATABASE_URL=sqlite+aiosqlite:///./data/shop.db

# Valores iniciales. Después se pueden cambiar desde /admin -> Configuración.
STORE_NAME=Shop Ultra
BINANCE_PAY_ID=123456789
BINANCE_PAY_NAME=TU NOMBRE EN BINANCE
SUPPORT_USERNAME=tu_usuario_telegram
BONUS_TIERS=50:2,100:5
MIN_DEPOSIT=1.00

# Verificación automática del historial de Binance Pay.
# Debe pertenecer a la misma cuenta que recibe el Pay ID.
# Crea una API key de solo lectura; no habilites trading, transferencias ni retiros.
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com
BINANCE_HISTORY_HOURS=72
BINANCE_CACHE_SECONDS=15
BINANCE_RECV_WINDOW_MS=5000
BINANCE_REQUEST_TIMEOUT_SECONDS=20
BINANCE_VERIFY_ATTEMPTS=2
BINANCE_VERIFY_RETRY_DELAY_SECONDS=8
VERIFICATION_COOLDOWN_SECONDS=15

# Operación
DROP_PENDING_UPDATES=false
LOG_LEVEL=INFO

# Varias APIs externas. Ejecuta configurar_apis.bat para crear/editar este archivo.
API_PROVIDERS_FILE=data/providers.json

# Compatibilidad con instalaciones anteriores de una sola API.
# Si estas variables ya existen y no hay providers.json, el bot las importa automáticamente.
# ProdSeller API v1 (catálogo y entrega automática de productos externos).
# La URL entregada por el proveedor usa HTTP sin cifrado. Solicita HTTPS cuando sea posible.
PRODSELLER_ENABLED=false
PRODSELLER_BASE_URL=http://51.77.244.194/v1
PRODSELLER_API_KEY=
PRODSELLER_ALLOW_INSECURE_HTTP=false
# Precio de venta inicial = costo del proveedor + este porcentaje.
PRODSELLER_MARKUP_PERCENT=20
# false conserva los precios editados manualmente durante la sincronización automática.
PRODSELLER_SYNC_PRICES=false
# Impide vender por debajo del costo informado por el proveedor.
PRODSELLER_ALLOW_BELOW_COST=false
# 0 desactiva la sincronización automática.
PRODSELLER_AUTO_SYNC_MINUTES=10
PRODSELLER_CACHE_SECONDS=60
PRODSELLER_TIMEOUT_SECONDS=20
PRODSELLER_ORDER_POLL_ATTEMPTS=4
PRODSELLER_ORDER_POLL_DELAY_SECONDS=2
